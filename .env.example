# Copy to .env and fill in after WashU IT registers the app.
# Until then: leave AUTH_REQUIRED unset (or false) — app works as today.

# --- Enable auth (lab / production) ---
# AUTH_REQUIRED=true
# SESSION_SECRET=generate-a-long-random-string

# --- WashU Entra (from IT app registration) ---
# ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ENTRA_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ENTRA_CLIENT_SECRET=your-client-secret
# ENTRA_REDIRECT_URI=http://127.0.0.1:8000/auth/callback

# --- Dev RBAC testing without Entra (only when Entra vars are empty) ---
# AUTH_DEV_EMAIL=you@wustl.edu
# AUTH_DEV_ROLES=Study.Admin

# Optional: map Entra group GUIDs → roles if not using app roles on groups
# ENTRA_GROUP_ROLE_MAP={"group-guid-here":"Study.Analyst"}
